#!/bin/bash
set -e
./compose/wait

# Patch upstream's broken Kafka preflight check (posthog/views.py:186).
# Upstream sets `"kafka": is_cloud() or settings.TEST` with no real probe,
# so self-hosted instances always see kafka=False and the setup wizard's
# Validate Implementation step blocks first-user registration. Our
# Kafka actually works (verified by producing to clickhouse_events_json
# from the web container at deploy time). Hardcoding True here matches
# reality for this stack.
sed -i 's|"kafka": is_cloud() or settings.TEST,|"kafka": True,  # patched-by-flndrn-wrapper|' /code/posthog/views.py 2>/dev/null || true

./bin/migrate
./bin/docker-server

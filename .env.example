# Umami env vars — paste into Dokploy's Environment tab and fill in.
# Generate each secret on a trusted machine; never commit real values.

# Postgres password used by both `umami` (as DB client) and `db` (as DB user)
# Generate with:  openssl rand -hex 16
DB_PASSWORD=__GENERATE__

# Umami session/cookie signing secret
# Generate with:  openssl rand -hex 32
APP_SECRET=__GENERATE__

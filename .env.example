# PostHog @ analytics.flndrn.com — Dokploy environment template
# Copy these into Dokploy's Environment tab and fill in placeholders.
# Do NOT commit a .env file with real values to git.

# === Domain ===
DOMAIN=analytics.flndrn.com

# === PostHog version pinning ===
# `latest` = always pull master image (rolling). Pin to a tag like
# release-1.252.0 once you want stable upgrades.
POSTHOG_APP_TAG=latest
POSTHOG_NODE_TAG=latest
REGISTRY_URL=posthog/posthog

# === Secrets (generate fresh — never reuse, never commit) ===
# POSTHOG_SECRET:       openssl rand -hex 32
# ENCRYPTION_SALT_KEYS: openssl rand -hex 16
POSTHOG_SECRET=__GENERATE_56_HEX_CHARS__
ENCRYPTION_SALT_KEYS=__GENERATE_32_HEX_CHARS__

# === Email (Resend SMTP via flndrn.com) ===
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=465
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=__YOUR_RESEND_API_KEY__
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_DEFAULT_FROM=PostHog <noreply@flndrn.com>

# Fallback if outbound port 465 is blocked:
# EMAIL_PORT=587
# EMAIL_USE_SSL=False
# EMAIL_USE_TLS=True

# === Optional ===
# Opt out of PostHog's own internal usage telemetry (the project sends
# anonymized usage stats to PostHog Cloud unless this is true)
OPT_OUT_CAPTURE=false
